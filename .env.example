# Copy this file to .env and fill in values.
# All values are auto-populated on first run — this file is just for reference.

# API key for authenticating requests.
# Auto-generated on first startup if left blank.
API_KEY=

# Path to the GGUF model file to serve.
# Set automatically when you download a model via the controller UI or bikai download.
MODEL_PATH=

# AI inference server port
PORT=8000

# Controller (management UI) port
CONTROLLER_PORT=8001

# Parallel inference slots (how many simultaneous users)
N_PARALLEL=4

# Context length per slot (tokens)
N_CTX=4096

# CPU threads for inference
N_THREADS=4

# Rate limit per IP
RATE_LIMIT=30/minute

# Public domain (set by bikai nginx)
DOMAIN=
