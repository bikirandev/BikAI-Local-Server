# Copy this file to .env and fill in values.
# The server will auto-generate API_KEY if left blank.

# Model to serve. Options:
#   gemma2:2b   (~1.6 GB, runs on CPU or low-end GPU) — default
#   gemma2      (~5.5 GB, 9B params)
#   gemma2:27b  (~16 GB, needs a good GPU)
MODEL_NAME=gemma2:2b


# API key for authenticating requests.
# Leave blank to auto-generate one on first startup.
API_KEY=''

# Rate limit per IP (requests/period).
# Examples: 30/minute, 100/hour, 1000/day
RATE_LIMIT=30/minute

# Ngrok auth token for public internet access.
# Get a free token at https://ngrok.com
NGROK_AUTH_TOKEN=
